#######################################################################
# CouponFind — environment configuration
# Copy to `.env` and fill in real secrets. NEVER commit `.env`.
#######################################################################

# ---- App ----
APP_NAME=CouponFind
APP_ENV=local                # local | production
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

# ---- Security ----
# Generate strong random values, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-64-char-random-hex-string
JWT_ACCESS_TTL=900           # seconds (15 min)
JWT_REFRESH_TTL=2592000      # seconds (30 days)
APP_KEY=change-me-32-byte-base64-key
SESSION_COOKIE=cf_session
COOKIE_SECURE=false          # true in production (HTTPS)

# ---- MySQL ----
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=couponfind
DB_USERNAME=couponfind
DB_PASSWORD=couponfind_secret
DB_ROOT_PASSWORD=root_secret

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Meilisearch ----
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-meili-master-key
MEILI_INDEX=coupons

# ---- AI providers (fallback chain: Groq -> Gemini -> OpenAI) ----
AI_PROVIDER_ORDER=groq,gemini,openai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Razorpay ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Python engine ----
ENGINE_USER_AGENT=CouponFindBot/1.0 (+https://couponfind.example)
ENGINE_CRAWL_CONCURRENCY=4
ENGINE_REQUEST_TIMEOUT=20
ENGINE_SCHEDULE_DISCOVERY_MINUTES=180
ENGINE_SCHEDULE_VALIDATE_MINUTES=360
ENGINE_SCHEDULE_SYNC_MINUTES=15
